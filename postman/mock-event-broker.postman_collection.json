{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "mock-event-broker",
    "description": "Lab tests for the HTTP event-broker simulator. Covers topics, queues, ack/nack, admin assert, and end-to-end queue flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{mock_username}}", "type": "string" },
      { "key": "password", "value": "{{mock_password}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8081" },
    { "key": "topic",    "value": "orders.created" },
    { "key": "queue",    "value": "orders.inbound" },
    { "key": "run_id",   "value": "pf_lab_001" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /admin/health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/admin/health" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Topics",
      "item": [
        {
          "name": "POST /topics/:topic/events — publish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "x-run-id",        "value": "{{run_id}}" },
              { "key": "x-correlation-id","value": "COR-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-001\",\n  \"amount\": 250.00,\n  \"currency\": \"EUR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/topics/{{topic}}/events" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has id', () => pm.expect(body.id).to.match(/^evt_/));",
                  "pm.collectionVariables.set('event_id', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /topics/:topic/events — list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/topics/{{topic}}/events?runId={{run_id}}",
              "query": [
                { "key": "runId", "value": "{{run_id}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('has events', () => pm.expect(pm.response.json().count).to.be.above(0));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Queues",
      "item": [
        {
          "name": "POST /queues/:queue/messages — enqueue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "x-run-id",     "value": "{{run_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<Order><OrderId>ORD-001</OrderId><Amount>250.00</Amount></Order>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('status queued', () => pm.expect(body.status).to.eql('queued'));",
                  "pm.collectionVariables.set('message_id', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /queues/:queue/messages — list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/queues/{{queue}}/messages?runId={{run_id}}",
              "query": [
                { "key": "runId", "value": "{{run_id}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('has messages', () => pm.expect(pm.response.json().count).to.be.above(0));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /queues/:queue/messages/next — dequeue",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages/next" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 or 204', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('status consumed', () => pm.expect(body.status).to.eql('consumed'));",
                  "  pm.collectionVariables.set('message_id', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /queues/:queue/messages/:id/ack",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages/{{message_id}}/ack" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status acknowledged', () => pm.expect(pm.response.json().status).to.eql('acknowledged'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /queues/:queue/messages/:id/nack",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"reason\": \"processing-error\" }",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages/{{message_id}}/nack" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status dead-letter', () => pm.expect(pm.response.json().status).to.eql('dead-letter'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "auth": {
        "type": "basic",
        "basic": [
          { "key": "username", "value": "{{admin_username}}", "type": "string" },
          { "key": "password", "value": "{{admin_password}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "GET /admin/events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/events?runId={{run_id}}",
              "query": [{ "key": "runId", "value": "{{run_id}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /admin/messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/messages?runId={{run_id}}",
              "query": [{ "key": "runId", "value": "{{run_id}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /admin/assert/events",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"{{topic}}\",\n  \"runId\": \"{{run_id}}\",\n  \"minCount\": 1,\n  \"maxWaitMs\": 10000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/assert/events" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('assert passed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().passed).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /admin/assert/messages — acknowledged",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"runId\": \"{{run_id}}\",\n  \"status\": \"acknowledged\",\n  \"minCount\": 1,\n  \"maxWaitMs\": 10000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/assert/messages" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('assert passed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().passed).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE /admin/reset",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/admin/reset" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Lab Flow — enqueue → dequeue → ack",
      "auth": {
        "type": "basic",
        "basic": [
          { "key": "username", "value": "{{mock_username}}", "type": "string" },
          { "key": "password", "value": "{{mock_password}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "1. Reset",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{admin_username}}", "type": "string" },
                { "key": "password", "value": "{{admin_password}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/admin/reset" }
          }
        },
        {
          "name": "2. Enqueue order message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "x-run-id",     "value": "{{run_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<Order><OrderId>ORD-FLOW-001</OrderId><Amount>500.00</Amount></Order>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('enqueued', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('message_id', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Dequeue next (simulates CPI consuming)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages/next" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('consumed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('consumed');",
                  "});",
                  "pm.collectionVariables.set('message_id', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4. Ack (simulates CPI confirming success)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/queues/{{queue}}/messages/{{message_id}}/ack" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('acknowledged', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('acknowledged');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "5. Assert acknowledged (evidence check)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{admin_username}}", "type": "string" },
                { "key": "password", "value": "{{admin_password}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queue\": \"{{queue}}\",\n  \"runId\": \"{{run_id}}\",\n  \"status\": \"acknowledged\",\n  \"minCount\": 1,\n  \"maxWaitMs\": 5000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/assert/messages" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('flow complete — message acknowledged', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().passed).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
