# Copy to .env for local development. Never commit .env.
PORT=8081
NODE_ENV=development

# In-memory store limits
MAX_EVENTS=1000
MAX_MESSAGES=500

# Publisher / consumer auth for /topics and /queues
# JSON array of {u, p} objects — supports multiple test systems
# → CPI Security Material (User Credentials): LAB_EVENTBROKER_BASIC
MOCK_USERS=[{"u":"lab-publisher","p":"CHANGEME"},{"u":"lab-consumer","p":"CHANGEME"}]
# Legacy single-user alternative:
# MOCK_USER=lab-publisher
# MOCK_PASSWORD=CHANGEME

# Admin auth for /admin/* (except /admin/health)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGEME

LOG_LEVEL=info
